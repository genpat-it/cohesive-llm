###############################################################################
#  IZS Bioinformatics AI Platform — environment configuration                  #
#                                                                              #
#  Copy this file to .env and edit values for your deployment.                 #
###############################################################################

# ─── DEPLOYMENT MODE ─────────────────────────────────────────────────────────
# DOMAIN: hostname or domain users will use to access the platform
#   localhost                  → local development
#   server.izs.intra           → internal IZS network (intranet)
#   ai.example.com             → public domain
DOMAIN=localhost

# HTTPS_MODE: how Caddy handles TLS
#   off       → HTTP only (port 80). Use for localhost or simple intranet.
#   internal  → Self-signed cert via Caddy local CA. Browser warning, but works
#               anywhere without owning a domain.
#   auto      → Automatic Let's Encrypt cert. Requires:
#               (1) public domain pointing at this server
#               (2) ports 80 and 443 reachable from the internet
HTTPS_MODE=off

# Email used by Let's Encrypt (only matters when HTTPS_MODE=auto)
ACME_EMAIL=admin@example.com


# ─── BACKEND ─────────────────────────────────────────────────────────────────
# Mistral API key (or whichever LLM provider you configured in backend/app/services/llm.py)
MISTRAL_API_KEY=your_mistral_api_key_here


# ─── NGSMANAGER FRAMEWORK ────────────────────────────────────────────────────
# The cohesive-ngsmanager repo will be cloned automatically into a Docker volume
# on first run. Backend reads it from /ngsmanager.
NGSMANAGER_REPO=https://github.com/genpat-it/cohesive-ngsmanager.git
NGSMANAGER_BRANCH=main


# ─── CADDY HOST PORTS ────────────────────────────────────────────────────────
CADDY_HOST_PORT=9000
CADDY_HOST_HTTPS_PORT=9443
CADDY_EXTRA_HTTP_PORT=9001


# ─── DATABASE ────────────────────────────────────────────────────────────────
POSTGRES_USER=cohesive
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=cohesive
DATABASE_URL=postgresql+psycopg2://cohesive:change_me_in_production@postgres:5432/cohesive


# ─── BACKEND AUTH ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_me_with_openssl_rand_hex_32

# Initial demo user, seeded automatically on first startup
DEMO_USER=demo
DEMO_PASSWORD=change_me_please


# ─── SECURITY HARDENING ──────────────────────────────────────────────────────
# Comma-separated allowed origins for CORS. Tighten in production.
#   dev:  http://localhost:9000,http://127.0.0.1:9000
#   prod: https://cohesive.izs.it
CORS_ORIGINS=http://localhost:9000,http://127.0.0.1:9000

# Session cookie hardening. Flip these in production:
#   COOKIE_SECURE=true     → cookie sent only over HTTPS
#   COOKIE_PATH=/llm       → scope cookie to the reverse-proxy sub-path
#   COOKIE_SAMESITE=lax    → "lax" | "strict" | "none"
COOKIE_SECURE=false
COOKIE_PATH=/
COOKIE_SAMESITE=lax

# Rate limit on POST /auth/login (per real client IP).
# Format: "<count>/<period>" — e.g. "5/minute", "20/hour", "100/day"
LOGIN_RATE_LIMIT=5/minute
