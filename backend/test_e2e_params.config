/*
 * Dummy params for E2E testing with -preview.
 * These values are never used — Nextflow -preview only validates
 * the workflow graph, not the actual execution.
 */
params {
    // Framework required
    cmp = "2026.CLI.00001.1.1"
    riscd = "260402-00001-0SQ_rawreads-import"
    outdir = "/tmp/izs-llm-e2e-test"

    // Step-specific databases and params
    step_3TX_species__kmerfinder__db = "/dummy/kmerfinder_db"
    step_3TX_species__vdabricate__db = "/dummy/vdabricate_db"
    step_3TX_class__kraken__db_kraken = "/dummy/kraken_db"
    step_3TX_class__kraken__db_bracken = "/dummy/bracken_db"
    step_3TX_class__kraken2__db = "/dummy/kraken2_db"
    step_3TX_class__centrifuge__db_name = "dummy"
    step_3TX_class__centrifuge__db_path = "/dummy/centrifuge_db"
    step_2AS_hybrid__unicycler__mode = "normal"
    step_2AS_filtering__seqio = "1000"
    step_4TY_MLST__mlst___excluded_schemas = ""

    // Module-level params
    analysis_type = "standard"
    coverage = "30"
    identity = "0.9"
    k = "21"
    kmers_size = "16"
    genus_species = "Unknown"
    hosts_dir = "/dummy/hosts"
    target = "genome"
    metadata = "/dummy/metadata.csv"
    geodata = "/dummy/geodata.csv"

    // Augur
    multi_clustering__augur__tree_method = "iqtree"
    multi_clustering__augur__ancestral_inference = "joint"
    multi_clustering__augur__refine_coalescent = "opt"
    multi_clustering__augur__traits_columns = "region"

    // CFSAN
    multi_clustering__cfsan__version = "2.0"

    // ReporTree
    multi_clustering__reportree__input = "vcf"
    multi_clustering__reportree__summary_date_aliases = "date"
    multi_clustering__reportree__summary_geo_column = "country"
    multi_clustering__reportree__summary_sample_column = "sample"

    // Panaroo
    multi_pangenome__panaroo__clean_mode = "strict"
    multi_pangenome__panaroo__threshold = "0.95"
    multi_pangenome__panaroo__family_threshold = "0.7"
    multi_pangenome__panaroo__len_dif_percent = "0.98"
    multi_pangenome__panaroo__threads = "4"
}
