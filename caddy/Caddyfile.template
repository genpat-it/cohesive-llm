# Caddyfile rendered from template at startup.
# Variables substituted by scripts/render-caddyfile.sh from .env values.

{
    auto_https ${CADDY_AUTO_HTTPS}
    email ${ACME_EMAIL}

    # Trust upstream reverse proxy headers (X-Forwarded-Proto, X-Real-IP) when
    # sitting behind another proxy. Set TRUSTED_PROXIES in .env to the upstream
    # proxy IP/CIDR, e.g. "10.10.0.0/16".
    servers {
        trusted_proxies static ${TRUSTED_PROXIES}
    }
}

${SITE_ADDRESS} {
    ${TLS_DIRECTIVE}

    # Backend API
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy backend:8080
    }

    # Frontend (static site)
    handle {
        reverse_proxy frontend:8080
    }

    log {
        output stdout
        format console
    }
}
