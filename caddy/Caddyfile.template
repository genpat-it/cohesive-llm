# Caddyfile rendered from template at startup.
# Variables substituted by scripts/render-caddyfile.sh from .env values.

{
    # Disable auto HTTPS when HTTPS_MODE=off
    auto_https ${CADDY_AUTO_HTTPS}
    email ${ACME_EMAIL}

    # Trust upstream reverse proxy headers (X-Forwarded-Proto, X-Real-IP)
    # when sitting behind another proxy. Set TRUSTED_PROXIES in .env to the
    # upstream proxy IP/CIDR, e.g. "10.10.0.0/16".
    servers {
        trusted_proxies static ${TRUSTED_PROXIES}
    }
}

${SITE_ADDRESS} {
    ${TLS_DIRECTIVE}

    # Authelia login UI - NO auth check on this path (otherwise infinite redirect loop)
    ${AUTHELIA_PORTAL_BLOCK}

    # Backend API - protected by auth check
    handle /api/* {
        ${AUTH_DIRECTIVE}
        uri strip_prefix /api
        reverse_proxy backend:8080
    }

    # Frontend (static site) - protected by auth check
    handle {
        ${AUTH_DIRECTIVE}
        reverse_proxy frontend:80
    }

    # Logging
    log {
        output stdout
        format console
    }
}
