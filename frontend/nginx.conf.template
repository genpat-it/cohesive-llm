# nginx config rendered at container start by the nginx-unprivileged image
# entrypoint, which runs `envsubst` over /etc/nginx/templates/*.template using
# the env vars passed from docker-compose.

server {
    listen 8080;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # Replace the literal __BASE_PATH__ placeholder in HTML/JS responses with
    # the value of the BASE_PATH env var. Default "/" → app at site root,
    # "/llm/" → app behind a /llm path-prefix proxy, etc. BASE_PATH MUST end
    # with a trailing slash.
    sub_filter '__BASE_PATH__' '${BASE_PATH}';
    sub_filter_once off;
    sub_filter_types text/html text/javascript application/javascript;

    location / {
        try_files $uri $uri/ /index.html;
    }
}
